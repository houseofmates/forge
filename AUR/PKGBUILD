# Maintainer: jimzrt <jimzrt1@gmail.com>

pkgname=forgevr-bin
pkgver=1.3.4
pkgrel=1
pkgdesc="A modern, cross-platform desktop application designed for managing and sideloading content onto Meta Quest devices"
arch=('x86_64' 'aarch64')
url="https://github.com/jimzrt/forgevr"
license=('GPL3')
depends=('fuse2')
optdepends=('libappindicator-gtk3: for tray icon support')
provides=('forgevr')
conflicts=('forgevr')
install=forgevr.install
options=('!debug' '!strip')
source=("forgevr.desktop"
        "forgevr.install"
        "https://raw.githubusercontent.com/jimzrt/forgevr/main/build/icon.png")
source_x86_64=("https://github.com/jimzrt/forgevr/releases/download/v${pkgver}/forgevr-${pkgver}-x86_64.AppImage")
source_aarch64=("https://github.com/jimzrt/forgevr/releases/download/v${pkgver}/forgevr-${pkgver}-arm64.AppImage")
sha256sums=('SKIP'
            'SKIP'
            'SKIP')
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

prepare() {
    if [ "$CARCH" = "x86_64" ]; then
        chmod +x "${srcdir}/forgevr-${pkgver}-x86_64.AppImage"
    elif [ "$CARCH" = "aarch64" ]; then
        chmod +x "${srcdir}/forgevr-${pkgver}-arm64.AppImage"
    fi
}

package() {
    # Determine the correct AppImage file based on architecture
    if [ "$CARCH" = "x86_64" ]; then
        _appimage="forgevr-${pkgver}-x86_64.AppImage"
    elif [ "$CARCH" = "aarch64" ]; then
        _appimage="forgevr-${pkgver}-arm64.AppImage"
    fi
  
    
    # Install the AppImage
    install -d "${pkgdir}/opt/forgevr"
    install -m755 "${srcdir}/${_appimage}" "${pkgdir}/opt/forgevr/forgevr.AppImage"
    
    
    # Create a wrapper script
    install -dm755 "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/forgevr" << 'EOF'
#!/bin/bash
exec /opt/forgevr/forgevr.AppImage "$@"
EOF
    chmod +x "${pkgdir}/usr/bin/forgevr"
    
    # Install desktop file
    install -Dm644 "${srcdir}/forgevr.desktop" "${pkgdir}/usr/share/applications/forgevr.desktop"
    
    # Install icon
    install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/pixmaps/forgevr.png"
    install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/icons/hicolor/256x256/apps/forgevr.png"
} 